generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExternalProvider {
  STEAM
  PLAYSTATION
  XBOX
  IGDB
  HLTB
  METACRITIC
}

enum UserGameStatus {
  OWNED
  WISHLIST
  PLAYING
  PLAYING_NEXT
  BACKLOG
  COMPLETED
  DROPPED
}

enum EntrySource {
  STEAM
  PLAYSTATION
  XBOX
  CSV
  MANUAL
  PHOTO
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  IMPORTED
  SKIPPED
  FAILED
}

enum PlatformSyncTrigger {
  MANUAL
  SCHEDULED
}

enum PlatformSyncRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum BacklogFriction {
  CHOICE_OVERLOAD
  TIME_COMMITMENT
  GENRE_FATIGUE
  LOW_CONFIDENCE_MATCH
  TOO_MANY_SIMILAR_GAMES
  STALE_SESSION
  COMPLETION_PRESSURE
  TECHNICAL_OR_PLATFORM_FRICTION
  UNKNOWN
}

enum AssistantSignalType {
  UNTOUCHED
  SAMPLED_DROPPED
  STALE_PLAYING
  FINISHABLE_SOON
  LIKELY_FINISHED
  WISHLIST_RISK
  BUY_RISK
  RETURN_CANDIDATE
  RELEASE_CANDIDATE
  FINISH_BEFORE_RELEASE
  RISKY_TO_START_BEFORE_RELEASE
  UPCOMING_RELEASE_WATCH
}

enum BetaTesterStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum FeedbackType {
  IMPROVEMENT
  BUG
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  DONE
  DECLINED
}

model User {
  id                       String                  @id @default(cuid())
  displayName              String?
  email                    String?                 @unique
  passwordHash             String?
  googleSubject            String?                 @unique
  youtubeSubject           String?                 @unique
  avatarUrl                String?
  onboardingAnswers        Json?
  onboardingCompletedAt    DateTime?
  onboardingSkippedAt      DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  externalAccounts         ExternalAccount[]
  gameEntries              UserGameEntry[]
  importJobs               ImportJob[]
  gameInsights             UserGameInsight[]
  assistantRuns            AssistantRun[]
  gameReviews              UserGameReview[]
  journalEntries           GameJournalEntry[]
  playerProfile            PlayerProfile?
  betaApplication          BetaTesterApplication?
  reviewedBetaApplications BetaTesterApplication[] @relation("BetaReviewer")
  feedbackSubmissions      Feedback[]
}

model ExternalAccount {
  id                String           @id @default(cuid())
  userId            String
  provider          ExternalProvider
  providerAccountId String
  username          String?
  displayName       String?
  avatarUrl         String?
  profileUrl        String?
  metadata          Json?
  lastSyncedAt      DateTime?
  nextSyncAt        DateTime?
  lastSyncAttemptAt DateTime?
  syncFailureCount  Int              @default(0)
  lastSyncErrorCode String?
  syncLeaseToken    String?
  syncLeaseExpiresAt DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameEntries       UserGameEntry[]
  platformSyncRuns  PlatformSyncRun[]

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
  @@index([provider, nextSyncAt])
  @@index([syncLeaseExpiresAt])
}

model PlatformSyncRun {
  id                String                @id @default(cuid())
  externalAccountId String
  provider          ExternalProvider
  trigger           PlatformSyncTrigger
  status            PlatformSyncRunStatus @default(PENDING)
  startedAt         DateTime?
  finishedAt        DateTime?
  leaseExpiresAt    DateTime?
  attempt           Int                   @default(1)
  syncedCount       Int?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  externalAccount   ExternalAccount       @relation(fields: [externalAccountId], references: [id], onDelete: Cascade)

  @@index([externalAccountId, createdAt])
  @@index([provider, status, createdAt])
  @@index([status, leaseExpiresAt])
}

model PlatformSyncSchedulerState {
  id              String    @id
  leaseToken      String?
  leaseExpiresAt  DateTime?
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Game {
  id                        String             @id @default(cuid())
  slug                      String             @unique
  name                      String
  normalizedName            String
  summary                   String?
  coverUrl                  String?
  heroUrl                   String?
  releaseDate               DateTime?
  aggregatedRating          Float?
  totalRatingCount          Int?
  genres                    Json?
  platforms                 Json?
  screenshots               Json?
  websites                  Json?
  metadataSource            ExternalProvider?
  igdbId                    Int?               @unique
  igdbSlug                  String?
  igdbCheckedAt             DateTime?
  hltbMainStoryMinutes      Int?
  hltbMainExtraMinutes      Int?
  hltbCompletionistMinutes  Int?
  hltbUpdatedAt             DateTime?
  hltbCheckedAt             DateTime?
  metacriticScore           Int?
  metacriticUrl             String?
  metacriticUpdatedAt       DateTime?
  metacriticCheckedAt       DateTime?
  upcomingReleases          Json?
  upcomingReleasesCheckedAt DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  providerLinks             GameProviderLink[]
  userEntries               UserGameEntry[]
  importRows                ImportRow[]
  userReviews               UserGameReview[]
  journalEntries            GameJournalEntry[]

  @@index([normalizedName])
}

model GameProviderLink {
  id                        String           @id @default(cuid())
  gameId                    String
  provider                  ExternalProvider
  providerGameId            String
  storeUrl                  String?
  rawData                   Json?
  // Cached id/name of the achievement or trophy awarded when the main story
  // ends ("credits roll"). Source is "ai", "heuristic", or "none" when the
  // game has no detectable story-completion achievement.
  storyAchievementId        String?
  storyAchievementName      String?
  storyAchievementSource    String?
  storyAchievementCheckedAt DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  game                      Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([provider, providerGameId])
  @@index([gameId])
}

model UserGameEntry {
  id                 String             @id @default(cuid())
  userId             String
  gameId             String
  status             UserGameStatus
  source             EntrySource
  provider           ExternalProvider?
  externalAccountId  String?
  platformName       String?
  playtimeMinutes    Int?
  playtimeSource     String?
  pendingPlaytimeMinutes Int?
  pendingPlaytimeSyncedAt DateTime?
  lastPlayedAt       DateTime?
  // Achievement/trophy progress (0-100). This is NOT story completion; a game
  // is "finished" when finishedAt is set or status is COMPLETED.
  completionPercent  Int?
  finishedAt         DateTime?
  // "manual" | "import" | "story_achievement" | "inferred"
  finishedSource     String?
  notes              String?
  isFavorite         Boolean            @default(false)
  isPhysicalCopy     Boolean            @default(false)
  startedAt          DateTime?
  manualStartedAt    DateTime?
  abandonedAt        DateTime?
  abandonReason      String?
  activeBacklog      Boolean            @default(true)
  userIntent         String?
  desiredSessionMin  Int?
  currentPlayingSlot Int?
  playingNextSlot    Int?
  plannedStartDate   DateTime?
  lastSyncedAt       DateTime?
  rawData            Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  game               Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  externalAccount    ExternalAccount?   @relation(fields: [externalAccountId], references: [id], onDelete: SetNull)
  insights           UserGameInsight[]
  reviews            UserGameReview[]
  journalEntries     GameJournalEntry[]

  @@unique([userId, gameId, status])
  @@unique([userId, currentPlayingSlot])
  @@unique([userId, playingNextSlot])
  @@index([userId, status])
}

model UserGameReview {
  id                  String            @id @default(cuid())
  userId              String
  userGameEntryId     String
  gameId              String
  provider            ExternalProvider?
  externalReviewId    String?
  title               String?
  body                String?
  ratingText          String?
  score               Int?
  recommended         Boolean?
  language            String?
  sourceUrl           String?
  reviewedAt          DateTime?
  updatedOnProviderAt DateTime?
  rawData             Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGameEntry       UserGameEntry     @relation(fields: [userGameEntryId], references: [id], onDelete: Cascade)
  game                Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([provider, externalReviewId])
  @@index([userId, createdAt])
  @@index([userGameEntryId])
  @@index([gameId, reviewedAt])
}

model GameJournalEntry {
  id                          String         @id @default(cuid())
  userId                      String
  userGameEntryId             String
  gameId                      String
  title                       String?
  body                        String?
  source                      String         @default("manual")
  externalSourceId            String?
  visibility                  String         @default("private")
  occurredAt                  DateTime       @default(now())
  mechanicsRecap              String?
  achievementSummary          String?
  latestAchievementName       String?
  latestAchievementUnlockedAt DateTime?
  inferenceConfidence         Int?
  audioTranscript             String?
  translatedTranscript        String?
  transcriptLanguage          String?
  transcriptConfidence        Float?
  rawData                     Json?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  user                        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGameEntry               UserGameEntry  @relation(fields: [userGameEntryId], references: [id], onDelete: Cascade)
  game                        Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  media                       JournalMedia[]

  @@unique([userGameEntryId, source, externalSourceId])
  @@index([userId, occurredAt])
  @@index([gameId, occurredAt])
  @@index([userGameEntryId, occurredAt])
}

model JournalMedia {
  id             String           @id @default(cuid())
  journalEntryId String
  kind           String
  url            String
  storageKey     String
  storageProvider String          @default("filesystem")
  mimeType       String
  fileName       String?
  sizeBytes      Int?
  source         String           @default("manual-upload")
  caption        String?
  createdAt      DateTime         @default(now())
  journalEntry   GameJournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([kind])
}

model UserGameInsight {
  id              String              @id @default(cuid())
  userId          String
  userGameEntryId String
  signalType      AssistantSignalType
  friction        BacklogFriction
  score           Int
  confidence      Int
  reasons         Json
  suggestedAction String?
  generatedBy     String              @default("rules")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGameEntry   UserGameEntry       @relation(fields: [userGameEntryId], references: [id], onDelete: Cascade)

  @@unique([userGameEntryId, signalType])
  @@index([userId, signalType])
  @@index([userId, score])
}

model AssistantRun {
  id            String   @id @default(cuid())
  userId        String
  inputSummary  Json
  outputSummary Json
  model         String?
  status        String
  error         String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AiSettings {
  id                                      String   @id
  assistantChatEnabled                    Boolean  @default(true)
  assistantPlayNextEnabled                Boolean  @default(true)
  assistantSummaryEnabled                 Boolean  @default(true)
  playerProfileEnabled                    Boolean  @default(true)
  photoImportEnabled                      Boolean  @default(true)
  voiceTranscriptionEnabled               Boolean  @default(true)
  voiceTranslationEnabled                 Boolean  @default(false)
  storyCompletionEnabled                  Boolean  @default(true)
  userDailySpendLimitUsd                  Float    @default(0.25)
  chatDailyTokenLimit                     Int      @default(20000)
  assistantPlayNextDailyTokenLimit        Int      @default(12000)
  playerProfileWeeklyCallLimit            Int      @default(2)
  photoImportDailyCallLimit               Int      @default(5)
  photoImportDailyFileLimit               Int      @default(10)
  voiceTranscriptionDailyCallLimit        Int      @default(10)
  userDailyLimit                          Int      @default(20)
  globalDailyLimit                        Int      @default(100)
  chatBudgetUnits                         Int      @default(3)
  chatMaxSteps                            Int      @default(3)
  chatMaxOutputTokens                     Int      @default(700)
  assistantPlayNextMaxOutputTokens        Int      @default(900)
  assistantSummaryMaxOutputTokens         Int      @default(650)
  playerProfileMaxCalls                   Int      @default(3)
  playerProfileMaxOutputTokens            Int      @default(1400)
  photoImportMaxFiles                     Int      @default(2)
  photoImportMaxFileBytes                 Int      @default(4194304)
  photoImportMaxOutputTokens              Int      @default(1000)
  photoImportMaxCandidates                Int      @default(30)
  voiceMaxFileBytes                       Int      @default(10485760)
  voiceRecordingMaxSeconds                Int      @default(180)
  voiceTranslationMaxOutputTokens         Int      @default(900)
  storyCompletionMaxClassificationsPerRun Int      @default(10)
  storyCompletionMaxOutputTokens          Int      @default(220)
  createdAt                               DateTime @default(now())
  updatedAt                               DateTime @updatedAt
}

model PlayerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  summary   String
  profile   Json
  toolTrace Json?
  model     String?
  status    String
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BetaTesterApplication {
  id              String           @id @default(cuid())
  userId          String           @unique
  name            String?
  platforms       Json?
  retroGames      String?
  status          BetaTesterStatus @default(DRAFT)
  justification   String?
  reviewedById    String?
  reviewedAt      DateTime?
  accessExpiresAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy      User?            @relation("BetaReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reviewedById])
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  type      FeedbackType
  status    FeedbackStatus @default(NEW)
  title     String
  details   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model ImportJob {
  id            String          @id @default(cuid())
  userId        String
  fileName      String
  status        ImportJobStatus @default(PENDING)
  columnMapping Json?
  summary       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  completedAt   DateTime?
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows          ImportRow[]

  @@index([userId, createdAt])
}

model ImportRow {
  id                String           @id @default(cuid())
  jobId             String
  rowIndex          Int
  rawData           Json
  normalizedTitle   String?
  platformName      String?
  statusText        String?
  playtimeMinutes   Int?
  completionPercent Int?
  notes             String?
  externalId        String?
  outcome           ImportRowStatus?
  error             String?
  matchedGameId     String?
  createdAt         DateTime         @default(now())
  job               ImportJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  matchedGame       Game?            @relation(fields: [matchedGameId], references: [id], onDelete: SetNull)

  @@index([jobId, rowIndex])
}
